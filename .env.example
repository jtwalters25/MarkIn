# ---- GitHub OAuth ---------------------------------------------------------
# Create at https://github.com/settings/developers → "New OAuth App"
#   Homepage URL:               http://localhost:3000
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Anthropic ------------------------------------------------------------
# Get at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ---- NextAuth -------------------------------------------------------------
# Generate the secret with:  openssl rand -base64 32
# NEXTAUTH_URL must match the origin the dev server is actually serving on.
# If port 3000 is taken and Next falls back to 3001, update this AND the
# GitHub OAuth callback URL to match, or kill the other process.
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ---- Database -------------------------------------------------------------
# Postgres (Supabase, Neon, Vercel Postgres, etc.). Use the pooled connection
# string for runtime and the direct one for migrations if your provider splits
# them (Supabase: "Connection pooling" → Transaction mode for DATABASE_URL).
DATABASE_URL=postgresql://user:pass@host:5432/markin

# ---- Scheduled PRs (cron) -------------------------------------------------
# Secret used by /api/schedule/run to authorize cron callers. Generate with:
#   openssl rand -hex 32
# In production, configure a cron (Vercel Cron, GitHub Actions, etc.) to POST
# to /api/schedule/run every minute with header `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=

# ---- Demo mode ------------------------------------------------------------
# When "true", auth is bypassed and the app returns canned data so you can
# explore the UI without GitHub OAuth. Set BOTH to "false" to use real auth.
NEXT_PUBLIC_DEMO_MODE=false
DEMO_MODE=false
